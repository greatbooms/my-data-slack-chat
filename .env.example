# 로컬 실행용 예시 환경변수입니다.
# 실제 값은 `.env` 파일에 복사해서 수정하세요.

SPRING_PROFILES_ACTIVE=local

# 애플리케이션 포트입니다. 생략하면 Spring Boot 기본값인 8080을 사용합니다.
SERVER_PORT=8080

# 로컬 Docker Compose PostgreSQL/pgvector 접속 정보입니다.
DATABASE_URL=jdbc:postgresql://localhost:5433/my_data
DATABASE_USERNAME=my_data
DATABASE_PASSWORD=my_data

# 로컬 관리자 API 토큰입니다.
ADMIN_API_TOKEN=local-admin-token

# Slack Events API 서명 검증용 시크릿입니다.
# 실제 Slack 앱을 연결할 때 Slack 앱 관리 화면의 Signing Secret 값으로 바꾸세요.
SLACK_SIGNING_SECRET=local-signing-secret
