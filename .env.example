# 로컬 실행용 예시 환경변수입니다.
# 실제 값은 `.env` 파일에 복사해서 수정하세요.

SPRING_PROFILES_ACTIVE=local

# 애플리케이션 포트입니다. 생략하면 프로젝트 기본값인 50506을 사용합니다.
SERVER_PORT=50506

# 로컬 Docker Compose PostgreSQL/pgvector 접속 정보입니다.
DATABASE_URL=jdbc:postgresql://localhost:5433/my_data
DATABASE_USERNAME=my_data
DATABASE_PASSWORD=my_data

# 초기 관리자 계정입니다. 이미 삭제되지 않은 관리자가 있으면 사용하지 않습니다.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me
ADMIN_BOOTSTRAP_DISPLAY_NAME=관리자

# Slack 수신 방식 선택입니다.
# 초기 로컬 개발에서는 토큰을 실제 값으로 바꾼 뒤 Socket Mode를 true로 켭니다.
SLACK_SOCKET_MODE_ENABLED=false
SLACK_HTTP_EVENTS_ENABLED=false

# Slack HTTP Events API 서명 검증용 시크릿입니다.
# SLACK_HTTP_EVENTS_ENABLED=true일 때만 필요합니다.
SLACK_SIGNING_SECRET=local-signing-secret

# Slack Socket Mode App-Level Token입니다.
# SLACK_SOCKET_MODE_ENABLED=true일 때 필요하며 보통 xapp-로 시작합니다.
SLACK_APP_TOKEN=

# Slack Web API Bot User OAuth Token입니다.
# SLACK_SOCKET_MODE_ENABLED=true일 때 필요하며 보통 xoxb-로 시작합니다.
SLACK_BOT_TOKEN=

# 임베딩 모델 이름입니다. 현재는 테스트/로컬 개발용 결정적 임베딩 클라이언트에서 사용합니다.
EMBEDDING_MODEL=deterministic-1536
