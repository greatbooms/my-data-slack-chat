# 로컬 실행용 예시 환경변수입니다. 실제 값은 `.env` 파일에 복사해서 수정하세요.
# 필수/선택 여부는 로컬 개발 기준입니다. 외부 연동 값은 해당 기능을 켤 때만 필요합니다.

# [필수] 로컬 실행 프로필입니다.
SPRING_PROFILES_ACTIVE=local

# [선택] 애플리케이션 포트입니다. 생략하면 50506을 사용합니다.
SERVER_PORT=50506

# [선택] 로컬 Docker Compose PostgreSQL/pgvector 접속 정보입니다.
# local 프로필 기본값과 같아서 보통 수정하지 않아도 됩니다.
DATABASE_URL=jdbc:postgresql://localhost:5433/my_data
DATABASE_USERNAME=my_data
DATABASE_PASSWORD=my_data

# [조건부 필수] 삭제되지 않은 관리자 계정이 없을 때 생성할 초기 관리자 계정입니다.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me
ADMIN_BOOTSTRAP_DISPLAY_NAME=관리자

# [선택] Slack 수신 방식 선택입니다. 기본값은 모두 비활성화입니다.
# 로컬 Slack 연동은 보통 Socket Mode만 true로 켭니다.
SLACK_SOCKET_MODE_ENABLED=false
SLACK_HTTP_EVENTS_ENABLED=false

# [조건부 필수] Slack HTTP Events API 서명 검증용 시크릿입니다.
# SLACK_HTTP_EVENTS_ENABLED=true일 때 필요합니다.
SLACK_SIGNING_SECRET=local-signing-secret

# [조건부 필수] Slack Socket Mode App-Level Token입니다.
# SLACK_SOCKET_MODE_ENABLED=true일 때 필요하며 보통 xapp-로 시작합니다.
SLACK_APP_TOKEN=

# [조건부 필수] Slack Web API Bot User OAuth Token입니다.
# SLACK_SOCKET_MODE_ENABLED=true일 때 필요하며 보통 xoxb-로 시작합니다.
SLACK_BOT_TOKEN=

# [조건부 필수] Notion Internal Integration Secret입니다.
# NOTION 데이터소스를 수집할 때 필요합니다.
NOTION_API_TOKEN=

# [선택] Notion API 설정입니다. 일반 개발에서는 기본값을 유지합니다.
NOTION_API_VERSION=2026-03-11
NOTION_BASE_URL=https://api.notion.com

# [선택] 임베딩 모델 이름입니다. 현재는 테스트/로컬 개발용 결정적 임베딩 클라이언트에서 사용합니다.
EMBEDDING_MODEL=deterministic-1536
